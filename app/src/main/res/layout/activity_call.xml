<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_header_gradient">

    <!-- Caller info -->
    <LinearLayout
        android:id="@+id/call_info_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/call_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp">

            <TextView
                android:id="@+id/call_initials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_initials_circle"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/call_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_initials_circle"
                android:scaleType="centerCrop"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/call_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/call_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Decline -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="48dp">

            <ImageButton
                android:id="@+id/call_decline_btn"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_call_end_btn"
                android:padding="16dp"
                android:src="@drawable/ic_call_end"
                android:contentDescription="Decline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:text="Decline" />

        </LinearLayout>

        <!-- Accept -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/call_accept_btn"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_tag_green"
                android:padding="16dp"
                android:src="@drawable/ic_call_voice"
                android:visibility="gone"
                android:contentDescription="Accept" />

            <TextView
                android:id="@+id/call_accept_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:visibility="gone"
                android:text="Accept" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>