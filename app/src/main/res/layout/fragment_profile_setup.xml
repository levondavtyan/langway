<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="12dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/setup_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Add a photo and a short bio so others can get to know you"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:alpha="0" />

        <FrameLayout
            android:id="@+id/setup_avatar_container"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:alpha="0">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_setup_circle" />

            <TextView
                android:id="@+id/setup_avatar_initials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📷"
                android:textSize="36sp" />

            <ImageView
                android:id="@+id/setup_avatar_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_setup_circle"
                android:visibility="gone" />

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="2dp"
                android:background="@drawable/bg_flag_badge"
                android:gravity="center"
                android:text="✏️"
                android:textSize="14sp" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:text="Tap to choose a photo"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/setup_bio_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="YOUR BIO"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Langway.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tell others a little about yourself…">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/setup_bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:maxLines="6"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLength="200"
                        android:textColor="@color/text_primary"
                        android:gravity="top" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Optional — you can add this later"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>