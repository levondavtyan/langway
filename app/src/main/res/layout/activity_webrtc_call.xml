<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote video (full screen) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/webrtc_remote_video"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Local video (picture-in-picture, top-right) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/webrtc_local_video"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status label -->
    <TextView
        android:id="@+id/webrtc_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:text="Connecting…"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Controls bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="48dp"
        android:paddingTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/webrtc_btn_mic"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_initials_circle"
            android:padding="14dp"
            android:src="@drawable/ic_mic_on"
            android:contentDescription="Toggle microphone" />

        <ImageButton
            android:id="@+id/webrtc_btn_end"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_call_end_btn"
            android:padding="16dp"
            android:src="@drawable/ic_call_end"
            android:contentDescription="End call" />

        <ImageButton
            android:id="@+id/webrtc_btn_camera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_initials_circle"
            android:padding="14dp"
            android:src="@drawable/ic_camera_on"
            android:contentDescription="Toggle camera" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>