<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Langway" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryContainer">@color/brand_green_light</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorOnPrimaryContainer">@color/brand_green_dark</item>
        <item name="colorSecondary">@color/brand_blue</item>
        <item name="colorSecondaryContainer">@color/brand_blue_light</item>
        <item name="colorOnSecondary">@color/text_on_brand</item>
        <item name="colorOnSecondaryContainer">@color/brand_blue_dark</item>
        <item name="colorTertiary">@color/brand_green_dark</item>
        <item name="colorTertiaryContainer">@color/brand_green_light</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">#FF5C7A</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Langway.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Langway.Large</item>
        <item name="materialButtonStyle">@style/Widget.Langway.Button</item>
        <item name="textInputStyle">@style/Widget.Langway.TextInput</item>
    </style>

    <style name="Theme.Langway" parent="Base.Theme.Langway" />

    <!-- ── Shape appearances ── -->
    <style name="ShapeAppearance.Langway.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.Langway.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- ── Primary filled button ──
         Disabled state: flat grey bg (#C5C5C5), grey text (#888).
         Uses a plain solid colour for disabled — no @color/ selector file needed.
    -->
    <style name="Widget.Langway.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_green</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">50dp</item>
        <!-- Suppress M3's own alpha-based disabled dimming so our DisabledAlpha override works -->
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ── Secondary outlined button ── -->
    <style name="Widget.Langway.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/brand_green_dark</item>
        <item name="strokeColor">@color/brand_green</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ── Danger (Remove) button ── -->
    <style name="Widget.Langway.Button.Danger" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/remove_btn</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <!-- ── TextInputLayout ── -->
    <style name="Widget.Langway.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="Widget.Langway.HeaderCard" parent="">
        <item name="android:background">@drawable/bg_header_gradient</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Langway.BottomBar" parent="">
        <item name="android:background">@color/surface</item>
        <item name="android:elevation">4dp</item>
    </style>

</resources>